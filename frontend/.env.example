# Kube-Tofu Frontend Configuration
# Copy this file to .env.local and customize

# ==================== Development ====================
# Backend API URL (local development)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# WebSocket URL (for real-time updates)
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# Admin Panel URL
NEXT_PUBLIC_ADMIN_URL=http://localhost:8000/admin

# ==================== Production ====================
# Uncomment these for production deployment

# NEXT_PUBLIC_API_URL=https://core.kube-tofu.dwin.codes/api/v1
# NEXT_PUBLIC_WS_URL=wss://core.kube-tofu.dwin.codes/ws
# NEXT_PUBLIC_ADMIN_URL=https://admin.kube-tofu.dwin.codes

# ==================== Options ====================
# Use mock data when backend is unavailable
NEXT_PUBLIC_USE_MOCK=false

# Enable debug logging
NEXT_PUBLIC_DEBUG=false
